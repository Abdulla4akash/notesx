---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Notes" pagefind>
  <main class="site-main home" data-pagefind-ignore>
    <section class="home-intro">
      <h1>Study Notes</h1>
      <div id="search" class="search"></div>
    </section>

    <section class="subject-grid home-section-grid" aria-label="Note sections">
      <a class="subject-card" href="/msc-ai-manchester/">
        <span class="subject-code">Degree Notes</span>
        <span class="subject-name">MSc AI Manchester</span>
      </a>
      <a class="subject-card" href="/self-learning/">
        <span class="subject-code">Independent Study</span>
        <span class="subject-name">Self Learning</span>
      </a>
    </section>
  </main>
</BaseLayout>
